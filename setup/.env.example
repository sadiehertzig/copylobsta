# === Required ===
OPENCLAW_TELEGRAM_BOT_TOKEN=     # From @BotFather
OPENCLAW_TELEGRAM_CHAT_ID=       # Your Telegram chat ID (send /start to your bot, check logs)

# === Model Providers (all three required for Three-Body Council) ===
ANTHROPIC_API_KEY=               # From platform.anthropic.com
OPENAI_API_KEY=                  # From platform.openai.com
GEMINI_API_KEY=                  # From aistudio.google.com

# === Optional: AWS Secrets Manager ===
# If set, keys are loaded from Secrets Manager instead of env vars.
# CopyLobsta sets this up automatically.
USE_AWS_SECRETS=false
AWS_SECRET_PREFIX=openclaw/
AWS_REGION=us-east-1

# === ClawHub ===
CLAWHUB_ENABLED=true
CLAWHUB_USERNAME=                # Set during setup or first ClawHub post

# === Mini App Services ===
# Sharing is disabled by default. Run /enable-sharing to turn on on-demand sharing.
COPYLOBSTA_SHARING_MODE=disabled
COPYLOBSTA_PORT=3457
TRIVIA_PORT=3456
TRIVIA_VOICE_BASE_URL=http://localhost:3456  # Local server URL (auto-set by install.sh)

# APP_BASE_URL is the public HTTPS URL that Telegram uses to open Mini Apps.
# You need a tunnel (e.g. Cloudflare Tunnel) pointing to localhost:3456.
# Example: npx cloudflared tunnel --url http://localhost:3456
APP_BASE_URL=                    # e.g. https://your-tunnel.trycloudflare.com

# === Spend Tracking ===
SPEND_TRACKER_PORT=9147
SPEND_TRACKER_DB=                # Default: ~/.openclaw/api_usage.db

# === Limits ===
MAX_CONVERSATION_HISTORY=20      # Messages kept in memory for context
