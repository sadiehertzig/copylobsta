# CopyLobsta environment variables
# These are loaded from ~/.openclaw/.env alongside other OpenClaw secrets

# Port for the CopyLobsta Express server
COPYLOBSTA_PORT=3457

# Public URL for the Mini App (Cloudflare tunnel or similar)
COPYLOBSTA_BASE_URL=https://your-tunnel.trycloudflare.com

# Shared secret for host bot → CopyLobsta /api/launch calls
# Generate with: openssl rand -hex 32
# COPYLOBSTA_LAUNCH_SECRET=...

# Session encryption key for data/sessions/*.json at-rest encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32
# COPYLOBSTA_SESSION_ENCRYPTION_KEY=...

# Recommended (secure): private S3 template + pre-signed URL at launch time
# COPYLOBSTA_TEMPLATE_S3_BUCKET=your-private-template-bucket
# COPYLOBSTA_TEMPLATE_S3_KEY=openclaw-runtime.yaml
# Optional if bucket region differs from AWS_REGION
# COPYLOBSTA_TEMPLATE_S3_REGION=us-east-1
# Optional pre-signed URL TTL (seconds, min 60, max 3600, default 600)
# COPYLOBSTA_TEMPLATE_URL_TTL_SECONDS=600

# Fallback (less secure): static public CloudFormation template URL
# Example: https://<bucket>.s3.<region>.amazonaws.com/openclaw-runtime.yaml
# CFN_TEMPLATE_URL=...

# Optional AWS region for CloudFormation quick create (default: us-east-1)
# AWS_REGION=us-east-1

# Shared with OpenClaw gateway (already in ~/.openclaw/.env)
# OPENCLAW_TELEGRAM_BOT_TOKEN=...
# OPENCLAW_TELEGRAM_CHAT_ID=...
