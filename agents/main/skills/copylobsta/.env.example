# CopyLobsta environment variables
# These are loaded from ~/.openclaw/.env alongside other OpenClaw secrets

# Port for the CopyLobsta Express server
COPYLOBSTA_PORT=3457

# Public URL for the Mini App (Cloudflare tunnel or similar)
COPYLOBSTA_BASE_URL=https://your-tunnel.trycloudflare.com

# Shared secret for host bot → CopyLobsta /api/launch calls
# Generate with: openssl rand -hex 32
# COPYLOBSTA_LAUNCH_SECRET=...

# Shared with OpenClaw gateway (already in ~/.openclaw/.env)
# OPENCLAW_TELEGRAM_BOT_TOKEN=...
# OPENCLAW_TELEGRAM_CHAT_ID=...
